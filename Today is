#!/bin/bash

# Exit immediately if a command exits with a non-zero status
set -e

# Load environment variables from local configuration
if [ -f .env ]; then
    export $(cat .env | xargs)
else
    echo "Error: .env file missing. Duplicate .env.example and populate keys."
    exit 1
fi

echo "===================================================="
echo " Starting MaShabak.io Deployment Pipeline on Base"
echo "===================================================="

# Compile contracts to ensure bytecode is valid and optimized
echo "Building contracts..."
forge build --optimize --optimizer-runs 200

# Select target network environment
NETWORK=${1:-sepolia}

if [ "$NETWORK" == "mainnet" ]; then
    RPC_URL=$BASE_MAINNET_RPC_URL
    echo "🚨 TARGET: Base Mainnet Production"
else
    RPC_URL=$BASE_SEPOLIA_RPC_URL
    echo "🧪 TARGET: Base Sepolia Testnet"
fi

# Execute on-chain deployment and code verification
echo "Broadcasting transaction to network..."
forge script script/Deploy.s.sol:DeployScript \
    --rpc-url "$RPC_URL" \
    --private-key "$DEPLOYER_PRIVATE_KEY" \
    --broadcast \
    --verify \
    --etherscan-api-key "$BASESCAN_API_KEY" \
    -vvvv

echo "===================================================="
echo " Deployment Complete & Verified on BaseScan!"
echo "===================================================="
