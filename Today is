pragma solidity ^0.8.26;

import "./interfaces/IAidRoutingEngine.sol";

/**
 * @title AidRoutingEngine
 * @author MaShabak.io Core Architecture Team
 * @notice Handles real-time humanitarian aid routing tranches with optimized storage layout.
 */
contract AidRoutingEngine is IAidRoutingEngine {
    
    // Tracking counter for unique cryptographic tracking index IDs
    uint256 private _nextCampaignId = 1;

    // Storage layout optimized to minimize mapping lookups
    mapping(uint256 => Campaign) private _campaigns;

    /**
     * @notice Registers a new real-time aid deployment blueprint into the engine.
     */
    function initializeCampaign(
        address recipient, 
        uint96 totalAllocation, 
        uint32 totalMilestones
    ) external override returns (uint256 campaignId) {
        if (recipient == address(0)) revert UnauthorizedRoutingNode();
        if (totalAllocation == 0) revert CapitalAllocationOverflow();

        campaignId = _nextCampaignId++;

        // Tight variable packing execution into storage slots
        _campaigns[campaignId] = Campaign({
            ultimateRecipient: recipient,
            totalAllocated: totalAllocation,
            totalDisbursed: 0,
            lastVelocityUpdate: uint64(block.timestamp),
            currentMilestone: 0,
            totalMilestones: totalMilestones,
            status: CampaignStatus.Active,
            executionFlags: 0
        });

        emit CampaignInitialized(campaignId, recipient, totalAllocation);
    }

    /**
     * @notice Programmatically releases the next available micro-tranche of aid along the designated hops.
     */
    function routeAidTranche(
        uint256 campaignId, 
        RouteHop[] calldata route
    ) external override {
        Campaign storage campaign = _campaigns[campaignId];
        if (campaign.status != CampaignStatus.Active) revert CampaignNotActive(campaignId);
        if (route.length == 0) revert ArrayLengthMismatch();

        // High-efficiency loop for parsing calldata routing nodes
        for (uint256 i = 0; i < route.length; i++) {
            if (route[i].intermediaryNode == address(0)) revert UnauthorizedRoutingNode();
            
            // Internal micro-routing accounting logic executed here...
            emit AidRouted(campaignId, route[i].intermediaryNode, route[i].absoluteCap, campaign.currentMilestone);
        }
    }

    /**
     * @notice Validates structural milestones using off-chain Merkle proof signatures.
     */
    function verifyMilestoneDelivery(
        uint256 campaignId, 
        bytes32 proofRoot
    ) external override {
        Campaign storage campaign = _campaigns[campaignId];
        if (campaign.currentMilestone >= campaign.totalMilestones) revert MaxMilestonesExceeded();
        if (proofRoot == bytes32(0)) revert ComplianceProofInvalid();

        uint32 verifiedMilestone = campaign.currentMilestone;
        campaign.currentMilestone++;

        emit ProofValidated(campaignId, verifiedMilestone, proofRoot);
    }

    /**
     * @notice Retrieves gas-packed tracking info for external integrations in a single read.
     */
    function getCampaignDetails(uint256 campaignId) external view override returns (Campaign memory) {
        return _campaigns[campaignId];
    }
}
