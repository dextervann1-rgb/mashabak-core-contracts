# VFV LLC — Deployment Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# Deployer private key — USE HARDWARE WALLET FOR MAINNET
# For Ledger: use frame.sh or @ledgerhq/hw-app-eth instead
# For testnet CI only: export from a dedicated test wallet
DEPLOYER_PRIVATE_KEY=YOUR_DEPLOYER_PRIVATE_KEY_HERE

# Basescan API key — get from https://basescan.org/apis
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY_HERE
